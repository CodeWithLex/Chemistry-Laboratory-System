<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="300.0" prefWidth="380.0" styleClass="validation-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers_for_ui.Validation_adminController">
    <stylesheets>
        <URL value="@/css/validation_admin.css" />
    </stylesheets>
    <children>
        <VBox alignment="CENTER" spacing="12.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
            <!-- Title -->
            <Label styleClass="validation-title" text="Admin Verification Required">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            <Label styleClass="validation-subtitle" text="Enter existing admin credentials to proceed" />

            <!-- Admin Username -->
            <Label styleClass="validation-label" text="Admin Username:" />
            <TextField fx:id="adminUsernameField" promptText="Enter admin username" styleClass="validation-field" />

            <!-- Admin Password -->
            <Label styleClass="validation-label" text="Admin Password:" />
            <PasswordField fx:id="adminPasswordField" promptText="Enter admin password" styleClass="validation-field" />

            <!-- Buttons -->
            <VBox alignment="CENTER" spacing="8.0">
                <padding>
                    <Insets top="8.0" />
                </padding>
                <Button fx:id="verifyBtn" mnemonicParsing="false" onAction="#verifyClicked" prefHeight="38.0" prefWidth="180.0" styleClass="verify-button" text="Verify &amp; Create">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
                <Button fx:id="cancelBtn" mnemonicParsing="false" onAction="#cancelClicked" prefHeight="32.0" prefWidth="180.0" styleClass="cancel-button" text="Cancel">
                    <font>
                        <Font name="System Bold" size="11.0" />
                    </font>
                </Button>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
