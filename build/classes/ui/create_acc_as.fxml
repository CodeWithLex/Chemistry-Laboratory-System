<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="500.0" styleClass="chooser-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers_for_ui.Create_acc_asController">
    <stylesheets>
        <URL value="@/css/create_acc_as.css" />
    </stylesheets>
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0">
            <!-- Title -->
            <Label styleClass="chooser-title" text="Create Account As">
                <font>
                    <Font name="System Bold" size="26.0" />
                </font>
            </Label>
            <Label styleClass="chooser-subtitle" text="Select your account type to proceed" />

            <!-- Buttons -->
            <VBox alignment="CENTER" spacing="15.0">
                <padding>
                    <Insets top="20.0" />
                </padding>

                <!-- Admin Button -->
                <Button fx:id="adminBtn" mnemonicParsing="false" onAction="#adminClicked" prefHeight="60.0" prefWidth="300.0" styleClass="admin-choice-button" text="Admin Account">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Button>

                <!-- Student Assistant Button -->
                <Button fx:id="saBtn" mnemonicParsing="false" onAction="#studentAssistantClicked" prefHeight="60.0" prefWidth="300.0" styleClass="sa-choice-button" text="Student Assistant Account">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Button>
            </VBox>

            <!-- Back to Login -->
            <VBox alignment="CENTER">
                <padding>
                    <Insets top="10.0" />
                </padding>
                <Button fx:id="backBtn" mnemonicParsing="false" onAction="#backClicked" prefHeight="36.0" prefWidth="200.0" styleClass="back-button" text="Back to Login">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
