<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0" prefWidth="700.0" spacing="10.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers_for_ui.GroupHistoryController">
   <padding>
      <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
   </padding>
   <children>
      <Label fx:id="titleLabel" text="History for Group" textFill="#2e7d32">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colReqId" prefWidth="80.0" text="Req ID" />
            <TableColumn fx:id="colApparatus" prefWidth="200.0" text="Apparatus" />
            <TableColumn fx:id="colQty" prefWidth="60.0" text="Qty" />
            <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
            <TableColumn fx:id="colRequested" prefWidth="180.0" text="Requested On" />
         </columns>
      </TableView>
      <HBox alignment="CENTER_RIGHT" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#closeWindow" text="Close" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>
