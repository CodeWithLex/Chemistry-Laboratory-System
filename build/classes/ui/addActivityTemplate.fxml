<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="500.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers_for_ui.AddActivityTemplateController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>
      <Label text="Compose Lab Activity Template" textFill="#10b981">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>
      
      <VBox spacing="8.0">
         <children>
            <Label text="Activity Name" style="-fx-font-weight: bold;" />
            <TextField fx:id="nameField" promptText="e.g., Simple Distillation" style="-fx-padding: 10;" />
         </children>
      </VBox>
      
      <VBox spacing="8.0">
         <children>
            <Label text="Description (Optional)" style="-fx-font-weight: bold;" />
            <TextArea fx:id="descriptionArea" prefHeight="80.0" promptText="Briefly describe the experiment..." style="-fx-padding: 5;" wrapText="true" />
         </children>
      </VBox>
      
      <VBox spacing="8.0" VBox.vgrow="ALWAYS">
         <children>
            <Label text="Apparatus Requirements" style="-fx-font-weight: bold;" />
            <HBox spacing="10.0">
               <children>
                  <ComboBox fx:id="apparatusComboBox" prefWidth="250.0" promptText="Select Apparatus..." style="-fx-padding: 5;" />
                  <TextField fx:id="qtyField" prefWidth="80.0" promptText="Qty" style="-fx-padding: 10;" />
                  <Button onAction="#addItemToList" style="-fx-background-color: #1a4d1a; -fx-text-fill: white; -fx-font-weight: bold;" text="+" />
               </children>
            </HBox>
            
            <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colItemName" prefWidth="280.0" text="APPARATUS" />
                  <TableColumn fx:id="colItemQty" prefWidth="100.0" text="FIXED QTY" />
               </columns>
               <placeholder>
                  <Label text="No apparatus added to this template." />
               </placeholder>
            </TableView>
            <Button onAction="#removeItemFromList" styleClass="action-button, reject-button" text="Remove Selected Item" />
         </children>
      </VBox>
      
      <HBox alignment="CENTER_RIGHT" spacing="15.0">
         <children>
            <Button onAction="#cancel" prefHeight="40.0" prefWidth="100.0" text="Cancel" />
            <Button onAction="#saveTemplate" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold;" text="Save Template" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>
