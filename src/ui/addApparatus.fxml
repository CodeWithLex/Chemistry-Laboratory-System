<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="250.0" prefWidth="350.0" spacing="15.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers_for_ui.AddApparatusController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label text="Add New Apparatus" textFill="#2e7d32">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <VBox spacing="5.0">
         <children>
            <Label text="Apparatus Name:" />
            <TextField fx:id="apparatusNameField" promptText="Enter apparatus name..." />
         </children>
      </VBox>
      <VBox spacing="5.0">
         <children>
            <Label text="Initial Quantity:" />
            <Spinner fx:id="quantitySpinner" prefWidth="150.0" />
         </children>
      </VBox>
      <HBox alignment="CENTER" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#addApparatus" style="-fx-background-color: #2e7d32; -fx-text-fill: white;" text="Add Apparatus" />
            <Button mnemonicParsing="false" onAction="#cancel" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>
