# ============================================================
# ChemLab System — Web Server Environment Variables
# ============================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file → rename it to: .env
#   2. Fill in your actual values below
#   3. NEVER commit .env to version control (it is already in .gitignore)
#
# IMPORTANT: Every variable listed here is REQUIRED.
# The server will refuse to start if any required variable is missing.
# ============================================================

# ── Supabase Database ──────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection Pooling
SUPABASE_HOST=aws-0-ap-northeast-2.pooler.supabase.com
SUPABASE_PORT=6543
SUPABASE_DB=postgres
SUPABASE_USER=postgres.YOUR_PROJECT_REF_HERE
SUPABASE_PASS=YOUR_DATABASE_PASSWORD_HERE

# ── Session ────────────────────────────────────────────────
# Generate a strong random secret. Example (run in terminal):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_48_CHARS

# ── Deployment Environment ──────────────────────────────────
# Set to 'production' on Railway/Render to enable secure cookies (HTTPS only).
# Leave as 'development' for local testing.
NODE_ENV=development

# ── Email (Gmail SMTP) ─────────────────────────────────────
# Use a Gmail App Password (not your normal Gmail password).
# Generate at: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_GMAIL_ADDRESS@gmail.com
MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD_HERE
MAIL_FROM=YOUR_GMAIL_ADDRESS@gmail.com
MAIL_FROM_NAME=ChemLab System

# ── Admin Notification Recipient ────────────────────────────
# Email address that receives new borrow request notifications.
ADMIN_EMAIL=admin@your-school.edu.ph
