# ============================================================
# ChemLab System — Web Server Environment Variables
# ============================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file → rename it to: .env
#   2. Fill in your actual values below
#   3. NEVER commit .env to version control
# ============================================================

# ── Supabase Database ──────────────────────────────────────
SUPABASE_HOST=your-db-host.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres.your-ref
SUPABASE_PASS=your-db-password

# ── Session ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=your-random-secret-at-least-48-chars

# ── Deployment ──────────────────────────────────────────────
NODE_ENV=production
# URL of your Render app (e.g., https://chemlab.onrender.com)
RENDER_EXTERNAL_URL=

# ── Email (Resend API) ──────────────────────────────────────
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# ── Admin Notification ──────────────────────────────────────
# Email address that receives borrow request alerts
ADMIN_EMAIL=admin@school.edu.ph
MAIL_FROM_NAME=ChemLab System
